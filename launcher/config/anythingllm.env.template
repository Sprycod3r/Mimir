# AnythingLLM Environment Configuration — Mimir
# This file is a template. Mimir's launcher writes the live .env to the
# AnythingLLM data directory at {drive}/Mimir/anythingllm/.env
# with STORAGE_DIR and model settings filled in at runtime.
#
# DO NOT edit this template to change your active model — use the
# Mimir launcher to select a model tier instead.

# ---- Server ----
SERVER_PORT=3001
DISABLE_TELEMETRY=true

# ---- Storage (filled in at runtime by launcher) ----
STORAGE_DIR=PLACEHOLDER_STORAGE_DIR

# ---- LLM Provider ----
LLM_PROVIDER=ollama
OLLAMA_BASE_PATH=http://127.0.0.1:11434
OLLAMA_MODEL_PREF=PLACEHOLDER_MODEL
OLLAMA_MODEL_TOKEN_LIMIT=PLACEHOLDER_CONTEXT_WINDOW

# ---- Embedding Engine ----
EMBEDDING_ENGINE=ollama
EMBEDDING_BASE_PATH=http://127.0.0.1:11434
EMBEDDING_MODEL_PREF=nomic-embed-text
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=512

# ---- Vector Database ----
# lancedb is built-in — no external service required
VECTOR_DB=lancedb

# ---- Auth (single-user local mode — no password required) ----
# JWT_SECRET is auto-generated by AnythingLLM on first launch if not set.
# AUTH_TOKEN controls API access. Leave blank for no-auth local mode.
AUTH_TOKEN=
JWT_SECRET=PLACEHOLDER_JWT_SECRET

# ---- Document Processing ----
DOCUMENT_PROCESSOR_NO_WATCH=false

# ---- No external calls ----
# These disable any AnythingLLM features that phone home
DISABLE_AGENTMCP=false
